{
	"modules-left": ["hyprland/workspaces", "hyprland/mode"],
	"modules-center": ["clock", "idle_inhibitor"],
	"modules-right": ["tray", "custom/spotify", "custom/scratchpad-indicator", "network","pulseaudio", "battery"],

	"hyprland/mode": {
		"format": "<span style=\"italic\">{}</span>"
	},
	"network": {
		"format-wifi": "{essid} ({signalStrength}%) ΎΘτ",
		"format-ethernet": "{ifname} ΎΔΒ",
		"format-disconnected": "ΎΔΒ",
		"max-length": 50,
		"on-click": "kitty -e 'nmtui'"
	},
	"idle_inhibitor": {
		"format": "{icon}",
		"format-icons": {
			"activated": "ΎΒχ",
			"deactivated": "ΎΒ░"
		},
	},
	"tray": {
		"icon-size": 15,
		"spacing": 10
	},
	"clock": {
		// "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
		// "format-alt": "{:%Y-%m-%d}"
		"on-click": "gnome-calendar"
	},
	"pulseaudio": {
		"format": "{volume}% {icon} ",
		"format-bluetooth": "{volume}% {icon}ΎΛΦ {format_source}",
		"format-bluetooth-muted": "Ύγσ {icon}ΎΛΦ {format_source}",
		"format-muted": "0% {icon} ",
		"format-source": "{volume}% ΎΕ░",
		"format-source-muted": "ΎΕ▒",
		"format-icons": {
			"headphone": "ΎΑξ",
			"hands-free": "ΎΑξ",
			"headset": "ΎΑξ",
			"phone": "ΎΓΧ",
			"portable": "ΎΓΧ",
			"car": "ΎΗ╣",
			"default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
		},
		"on-click": "pavucontrol"
	},
	"battery": {
	    "interval": 60,
	    "states": {
	        "warning": 30,
	        "critical": 15
	    },
	    "format": "{capacity}% {icon}",
	    "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"],
	    "max-length": 25
	},
	"custom/spotify": {
		"format": "≤░ΥΘ",
		"on-click": "bash ~/.config/eww/scripts/toggle-spotify.sh",
		"tooltip": false,
	},
	"custom/power": {
		"format": "ΎΑΣ ",
		"on-click": "wlogout"
	},
	"custom/scratchpad-indicator": {
		"format-text": "{}hi",
		"return-type": "json",
		"interval": 3,
		"exec": "~/.local/bin/scratchpad-indicator 2> /dev/null",
		"exec-if": "exit 0",
		"on-click": "swaymsg 'scratchpad show'",
		"on-click-right": "swaymsg 'move scratchpad'"
	}
}
